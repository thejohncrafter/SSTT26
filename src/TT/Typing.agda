
open import OpsNotation
open import HEq

open import TT.Syntax

module TT.Typing where

data _вКҐ_вЙ°_    : (ќУ : Ctx) {d : Dim} (A B : Typ ќУ d) вЖТ Set
data _вКҐ_вЙ°_вИЈ_  : (ќУ : Ctx) {d : Dim} (t u : Trm ќУ d) (A : Typ ќУ d) вЖТ Set

infix 4 _вКҐ_вЙ°_
infix 4 _вКҐ_вЙ°_вИЈ_

data _вКҐ : (ќУ : Ctx) вЖТ Set
data _вКҐ_ : (ќУ : Ctx) {d : Dim} (A : Typ ќУ d) вЖТ Set
data _вКҐ_вИЈ_ : (ќУ : Ctx) {d : Dim} (t : Trm ќУ d) (A : Typ ќУ d) вЖТ Set

infix 4 _вКҐ
infix 4 _вКҐ_
infix 4 _вКҐ_вИЈ_

data _вКҐ_вЙ°_ where
  -- generators : none at the moment

  -- reflexive closure
  refl : {d : Dim}
       вЖТ {ќУ : Ctx}     вЖТ ќУ вКҐ
       вЖТ {A : Typ ќУ d} вЖТ ќУ вКҐ A
       вЖТ ќУ вКҐ A вЙ° A

  -- transitive closure
  trans : {d : Dim}
        вЖТ {ќУ : Ctx}     вЖТ ќУ вКҐ
        вЖТ {A : Typ ќУ d} вЖТ ќУ вКҐ A
        вЖТ {B : Typ ќУ d} вЖТ ќУ вКҐ B
        вЖТ {C : Typ ќУ d} вЖТ ќУ вКҐ C
        вЖТ ќУ вКҐ A вЙ° B
        вЖТ ќУ вКҐ B вЙ° C
        вЖТ ќУ вКҐ A вЙ° C

  -- symmetric closure
  symm : {d : Dim}
       вЖТ {ќУ : Ctx}     вЖТ ќУ вКҐ
       вЖТ {A : Typ ќУ d} вЖТ ќУ вКҐ A
       вЖТ {B : Typ ќУ d} вЖТ ќУ вКҐ B
       вЖТ ќУ вКҐ A вЙ° B
       вЖТ ќУ вКҐ B вЙ° A

  -- congruence closure: minimal dependent type theory
  ќ†вВБ : {dвВА dвВБ : Dim}
     вЖТ {ќУ : Ctx}            вЖТ ќУ вКҐ
     вЖТ {A B : Typ ќУ dвВА}     вЖТ ќУ вКҐ A вЖТ ќУ вКҐ B вЖТ ќУ вКҐ A вЙ° B
     вЖТ {F : Typ (ќУ , A) dвВБ} вЖТ ќУ , A вКҐ F
     вЖТ ќУ вКҐ ќ† A F вЙ° ќ† B (F [ rew A B ])
  ќ†вВВ : {dвВА dвВБ : Dim}
     вЖТ {ќУ : Ctx}              вЖТ ќУ вКҐ
     вЖТ {A : Typ ќУ dвВА}         вЖТ ќУ вКҐ A
     вЖТ {F G : Typ (ќУ , A) dвВБ} вЖТ ќУ , A вКҐ F
                              вЖТ ќУ , A вКҐ G
                              вЖТ ќУ , A вКҐ F вЙ° G
     вЖТ ќУ вКҐ ќ† A F вЙ° ќ† A G
  E  : {d : Dim}
     вЖТ {ќУ : Ctx}         вЖТ ќУ вКҐ
     вЖТ {t u : Trm ќУ +0d} вЖТ ќУ вКҐ t вИЈ U d
                         вЖТ ќУ вКҐ u вИЈ U d
                         вЖТ ќУ вКҐ t вЙ° u вИЈ U d
     вЖТ ќУ вКҐ E d t вЙ° E d u

  -- congruence closure: equality
  вЙГвВБ : {ќУ : Ctx}         вЖТ ќУ вКҐ
     вЖТ {A B : Typ ќУ +0d} вЖТ ќУ вКҐ A
                         вЖТ ќУ вКҐ B
                         вЖТ ќУ вКҐ A вЙ° B
     вЖТ {t : Trm ќУ +0d}   вЖТ ќУ вКҐ t вИЈ A
     вЖТ {u : Trm ќУ +0d}   вЖТ ќУ вКҐ u вИЈ A
     вЖТ ќУ вКҐ вЙГ A t u вЙ° вЙГ B t u
  вЙГвВВ : {ќУ : Ctx}           вЖТ ќУ вКҐ
     вЖТ {A : Typ ќУ +0d}     вЖТ ќУ вКҐ A
     вЖТ {tвВБ tвВВ : Trm ќУ +0d} вЖТ ќУ вКҐ tвВБ вИЈ A
                           вЖТ ќУ вКҐ tвВВ вИЈ A
                           вЖТ ќУ вКҐ tвВБ вЙ° tвВВ вИЈ A
     вЖТ {u : Trm ќУ +0d} вЖТ ќУ вКҐ u вИЈ A
     вЖТ ќУ вКҐ вЙГ A tвВБ u вЙ° вЙГ A tвВВ u
  вЙГвВГ : {ќУ : Ctx}           вЖТ ќУ вКҐ
     вЖТ {A : Typ ќУ +0d}     вЖТ ќУ вКҐ A
     вЖТ {t : Trm ќУ +0d}     вЖТ ќУ вКҐ t вИЈ A
     вЖТ {uвВБ uвВВ : Trm ќУ +0d} вЖТ ќУ вКҐ uвВБ вИЈ A
                           вЖТ ќУ вКҐ uвВВ вИЈ A
                           вЖТ ќУ вКҐ uвВБ вЙ° uвВВ вИЈ A
     вЖТ ќУ вКҐ вЙГ A t uвВБ вЙ° вЙГ A t uвВВ

data _вКҐ_вЙ°_вИЈ_ where
  -- generators: minimal dependent type theory
  ќ≤ : {dвВА dвВБ : Dim}
    вЖТ {ќУ : Ctx}            вЖТ ќУ вКҐ
    вЖТ {A : Typ ќУ dвВА}       вЖТ ќУ вКҐ A
    вЖТ {F : Typ (ќУ , A) dвВБ} вЖТ ќУ , A вКҐ F
    вЖТ {f : Trm (ќУ , A) dвВБ} вЖТ ќУ , A вКҐ f вИЈ F
    вЖТ {B : Typ ќУ dвВА}       вЖТ ќУ вКҐ B
    вЖТ {t : Trm ќУ dвВА}       вЖТ ќУ вКҐ t вИЈ B
    вЖТ ќУ вКҐ A вЙ° B
    вЖТ ќУ вКҐ  ¬Ј A F (∆Ы A F f) B t
        вЙ° f [ sub t ]
        вИЈ F [ sub t ]
  ќЈ : {dвВА dвВБ : Dim}
    вЖТ {ќУ : Ctx}            вЖТ ќУ вКҐ
    вЖТ {A : Typ ќУ dвВА}       вЖТ ќУ вКҐ A
    вЖТ {F : Typ (ќУ , A) dвВБ} вЖТ ќУ , A вКҐ F
    вЖТ {f : Trm ќУ dвВБ}       вЖТ ќУ вКҐ f вИЈ ќ† A F
    вЖТ ќУ вКҐ  f
        вЙ° ∆Ы A F (¬Ј (A [ wkn A ]) (F [ wkn A , A ]) (f [ wkn A ]) (A [ wkn A ]) (` (A [ wkn A ]) z))
        вИЈ ќ† A F
        
  -- generators: proof-irrelevant propositions
  irrel : {ќУ : Ctx}       вЖТ ќУ вКҐ
        вЖТ {A : Typ ќУ -1d} вЖТ ќУ вКҐ A
        вЖТ {t : Trm ќУ -1d} вЖТ ќУ вКҐ t вИЈ A
        вЖТ {u : Trm ќУ -1d} вЖТ ќУ вКҐ u вИЈ A
        вЖТ ќУ вКҐ t вЙ° u вИЈ A

  -- generators: equality
  вЙГind-ќ≤ : {dвВА : Dim}
         вЖТ {ќУ : Ctx}                                вЖТ ќУ вКҐ
         вЖТ {AвВБ : Typ ќУ +0d}                         вЖТ ќУ вКҐ AвВБ
         вЖТ {AвВВ : Typ (ќУ , AвВБ) +0d}                  вЖТ ќУ , AвВБ вКҐ AвВВ
         вЖТ {tвВБ : Trm ќУ +0d}                         вЖТ ќУ вКҐ tвВБ вИЈ AвВБ
         вЖТ {tвВВ : Trm (ќУ , AвВБ) +0d}                  вЖТ ќУ , AвВБ вКҐ tвВВ вИЈ AвВВ
         вЖТ {F : Typ (ќУ , AвВБ , вЙГ AвВВ tвВВ (` AвВВ z)) dвВА} вЖТ ќУ , AвВБ , вЙГ AвВВ tвВВ (` AвВВ z) вКҐ F
         вЖТ {f : Trm ќУ dвВА}                           вЖТ ќУ вКҐ f вИЈ F [ sub tвВБ , _ ] [ sub (вЙГrfl AвВБ tвВБ) ]
         вЖТ AвВБ [ wkn AвВБ ] вЙЕ AвВВ
         вЖТ tвВБ [ wkn AвВБ ] вЙЕ tвВВ
         вЖТ ќУ вКҐ  вЙГind AвВБ AвВВ tвВБ tвВВ F f tвВБ (вЙГrfl AвВБ tвВБ)
             вЙ° f
             вИЈ F [ sub tвВБ , _ ] [ sub (вЙГrfl AвВБ tвВБ) ]

  -- reflexive closure
  refl : {d : Dim}
       вЖТ {ќУ : Ctx}     вЖТ ќУ вКҐ
       вЖТ {A : Typ ќУ d} вЖТ ќУ вКҐ A
       вЖТ {t : Trm ќУ d} вЖТ ќУ вКҐ t вИЈ A
       вЖТ ќУ вКҐ t вЙ° t вИЈ A

  -- transitive closure
  trans : {d : Dim}
        вЖТ {ќУ : Ctx}     вЖТ ќУ вКҐ
        вЖТ {A : Typ ќУ d} вЖТ ќУ вКҐ A
        вЖТ {s : Trm ќУ d} вЖТ ќУ вКҐ s вИЈ A
        вЖТ {t : Trm ќУ d} вЖТ ќУ вКҐ t вИЈ A
        вЖТ {u : Trm ќУ d} вЖТ ќУ вКҐ u вИЈ A
        вЖТ ќУ вКҐ s вЙ° t вИЈ A
        вЖТ ќУ вКҐ t вЙ° u вИЈ A
        вЖТ ќУ вКҐ s вЙ° u вИЈ A

  -- symmetric closure
  symm : {d : Dim}
       вЖТ {ќУ : Ctx}     вЖТ ќУ вКҐ
       вЖТ {A : Typ ќУ d} вЖТ ќУ вКҐ A
       вЖТ {t : Trm ќУ d} вЖТ ќУ вКҐ t вИЈ A
       вЖТ {u : Trm ќУ d} вЖТ ќУ вКҐ u вИЈ A
       вЖТ ќУ вКҐ t вЙ° u вИЈ A
       вЖТ ќУ вКҐ u вЙ° t вИЈ A

  -- congruence closure
  conv : {d : Dim}
       вЖТ {ќУ : Ctx}       вЖТ ќУ вКҐ
       вЖТ {A B : Typ ќУ d} вЖТ ќУ вКҐ A
                         вЖТ ќУ вКҐ B
                         вЖТ ќУ вКҐ A вЙ° B
       вЖТ {t : Trm ќУ d}   вЖТ ќУ вКҐ t вИЈ A
       вЖТ {u : Trm ќУ d}   вЖТ ќУ вКҐ u вИЈ A
                         вЖТ ќУ вКҐ t вЙ° u вИЈ A
       вЖТ ќУ вКҐ t вЙ° u вИЈ B

  -- congruence closure: minimal dependent type theory
  ∆ЫвВБ : {dвВА dвВБ : Dim}
     вЖТ {ќУ : Ctx}            вЖТ ќУ вКҐ
     вЖТ {A B : Typ ќУ dвВА}     вЖТ ќУ вКҐ A
                            вЖТ ќУ вКҐ B
                            вЖТ ќУ вКҐ A вЙ° B
     вЖТ {F : Typ (ќУ , A) dвВБ} вЖТ ќУ , A вКҐ F
     вЖТ {f : Trm (ќУ , A) dвВБ} вЖТ ќУ , A вКҐ f вИЈ F
     вЖТ ќУ вКҐ ∆Ы A F f вЙ° ∆Ы B (F [ rew A B ]) (f [ rew A B ]) вИЈ ќ† A F
  ∆ЫвВВ : {dвВА dвВБ : Dim}
     вЖТ {ќУ : Ctx}              вЖТ ќУ вКҐ
     вЖТ {A : Typ ќУ dвВА}         вЖТ ќУ вКҐ A
     вЖТ {F G : Typ (ќУ , A) dвВБ} вЖТ ќУ , A вКҐ F
                              вЖТ ќУ , A вКҐ G
                              вЖТ ќУ , A вКҐ F вЙ° G
     вЖТ {f : Trm (ќУ , A) dвВБ}   вЖТ ќУ , A вКҐ f вИЈ F
     вЖТ ќУ вКҐ ∆Ы A F f вЙ° ∆Ы A G f вИЈ ќ† A F
  ∆ЫвВГ : {dвВА dвВБ : Dim}
     вЖТ {ќУ : Ctx}              вЖТ ќУ вКҐ
     вЖТ {A : Typ ќУ dвВА}         вЖТ ќУ вКҐ A
     вЖТ {F : Typ (ќУ , A) dвВБ}   вЖТ ќУ , A вКҐ F
     вЖТ {f g : Trm (ќУ , A) dвВБ} вЖТ ќУ , A вКҐ f вИЈ F
                              вЖТ ќУ , A вКҐ g вИЈ F
                              вЖТ ќУ , A вКҐ f вЙ° g вИЈ F
     вЖТ ќУ вКҐ ∆Ы A F f вЙ° ∆Ы A F g вИЈ ќ† A F
  ¬ЈвВБ : {dвВА dвВБ : Dim}
     вЖТ {ќУ : Ctx}            вЖТ ќУ вКҐ
     вЖТ {A C : Typ ќУ dвВА}     вЖТ ќУ вКҐ A
                            вЖТ ќУ вКҐ C
                            вЖТ ќУ вКҐ A вЙ° C
     вЖТ {F : Typ (ќУ , A) dвВБ} вЖТ ќУ , A вКҐ F
     вЖТ {f : Trm ќУ dвВБ}       вЖТ ќУ вКҐ f вИЈ ќ† A F
     вЖТ {B : Typ ќУ dвВА}       вЖТ ќУ вКҐ B
     вЖТ {t : Trm ќУ dвВА}       вЖТ ќУ вКҐ t вИЈ B
     вЖТ ќУ вКҐ ¬Ј A F f B t вЙ° ¬Ј C (F [ rew A C ]) f B t вИЈ F [ sub t ]
  ¬ЈвВВ : {dвВА dвВБ : Dim}
     вЖТ {ќУ : Ctx}           вЖТ ќУ вКҐ
     вЖТ {A : Typ ќУ dвВА}         вЖТ ќУ вКҐ A
     вЖТ {F G : Typ (ќУ , A) dвВБ} вЖТ ќУ , A вКҐ F
                           вЖТ ќУ , A вКҐ G
                           вЖТ ќУ , A вКҐ F вЙ° G
     вЖТ {f : Trm ќУ dвВБ}         вЖТ ќУ вКҐ f вИЈ ќ† A F
     вЖТ {B : Typ ќУ dвВА}         вЖТ ќУ вКҐ B
     вЖТ {t : Trm ќУ dвВА}         вЖТ ќУ вКҐ t вИЈ B
     вЖТ ќУ вКҐ ¬Ј A F f B t вЙ° ¬Ј A G f B t вИЈ F [ sub t ]
  ¬ЈвВГ : {dвВА dвВБ : Dim}
     вЖТ {ќУ : Ctx}            вЖТ ќУ вКҐ
     вЖТ {A : Typ ќУ dвВА}       вЖТ ќУ вКҐ A
     вЖТ {F : Typ (ќУ , A) dвВБ} вЖТ ќУ , A вКҐ F
     вЖТ {f g : Trm ќУ dвВБ}     вЖТ ќУ вКҐ f вИЈ ќ† A F
                            вЖТ ќУ вКҐ g вИЈ ќ† A F
                            вЖТ ќУ вКҐ f вЙ° g вИЈ ќ† A F
     вЖТ {B : Typ ќУ dвВА}       вЖТ ќУ вКҐ B
     вЖТ {t : Trm ќУ dвВА}       вЖТ ќУ вКҐ t вИЈ B
     вЖТ ќУ вКҐ ¬Ј A F f B t вЙ° ¬Ј A F g B t вИЈ F [ sub t ]
  ¬ЈвВД : {dвВА dвВБ : Dim}
     вЖТ {ќУ : Ctx}            вЖТ ќУ вКҐ
     вЖТ {A : Typ ќУ dвВА}       вЖТ ќУ вКҐ A
     вЖТ {F : Typ (ќУ , A) dвВБ} вЖТ ќУ , A вКҐ F
     вЖТ {f : Trm ќУ dвВБ}       вЖТ ќУ вКҐ f вИЈ ќ† A F
     вЖТ {B D : Typ ќУ dвВА}     вЖТ ќУ вКҐ B
                            вЖТ ќУ вКҐ D
                            вЖТ ќУ вКҐ B вЙ° D
     вЖТ {t : Trm ќУ dвВА}       вЖТ ќУ вКҐ t вИЈ B
     вЖТ ќУ вКҐ ¬Ј A F f B t вЙ° ¬Ј A F f D t вИЈ F [ sub t ]
  ¬ЈвВЕ : {dвВА dвВБ : Dim}
     вЖТ {ќУ : Ctx}            вЖТ ќУ вКҐ
     вЖТ {A : Typ ќУ dвВА}       вЖТ ќУ вКҐ A
     вЖТ {F : Typ (ќУ , A) dвВБ} вЖТ ќУ , A вКҐ F
     вЖТ {f : Trm ќУ dвВБ}       вЖТ ќУ вКҐ f вИЈ ќ† A F
     вЖТ {B : Typ ќУ dвВА}       вЖТ ќУ вКҐ B
     вЖТ {t u : Trm ќУ dвВА}     вЖТ ќУ вКҐ t вИЈ B
                            вЖТ ќУ вКҐ u вИЈ B
                            вЖТ ќУ вКҐ t вЙ° u вИЈ B
     вЖТ ќУ вКҐ ¬Ј A F f B t вЙ° ¬Ј A F f B u вИЈ F [ sub t ]

  -- congruence closure: equality
  вЙГrflвВБ : {ќУ : Ctx}         вЖТ ќУ вКҐ
        вЖТ {A B : Typ ќУ +0d} вЖТ ќУ вКҐ A вЖТ ќУ вКҐ B вЖТ ќУ вКҐ A вЙ° B
        вЖТ {t : Trm ќУ +0d}   вЖТ ќУ вКҐ t вИЈ A
        вЖТ ќУ вКҐ вЙГrfl A t вЙ° вЙГrfl B t вИЈ вЙГ A t t
  вЙГrflвВВ : {ќУ : Ctx}         вЖТ ќУ вКҐ
        вЖТ {A : Typ ќУ +0d}   вЖТ ќУ вКҐ A
        вЖТ {t u : Trm ќУ +0d} вЖТ ќУ вКҐ t вИЈ A вЖТ ќУ вКҐ u вИЈ A вЖТ ќУ вКҐ t вЙ° u вИЈ A
        вЖТ ќУ вКҐ вЙГrfl A t вЙ° вЙГrfl A u вИЈ вЙГ A t t
  вЙГindвВБ  : {dвВА : Dim}
         вЖТ {ќУ : Ctx}                                   вЖТ ќУ вКҐ
         вЖТ {AвВБ BвВБ : Typ ќУ +0d}                         вЖТ ќУ вКҐ AвВБ
                                                       вЖТ ќУ вКҐ BвВБ
                                                       вЖТ ќУ вКҐ AвВБ вЙ° BвВБ
         вЖТ {AвВВ : Typ (ќУ , AвВБ) +0d}                     вЖТ ќУ , AвВБ вКҐ AвВВ
         вЖТ {tвВБ : Trm ќУ +0d}                            вЖТ ќУ вКҐ tвВБ вИЈ AвВБ
         вЖТ {tвВВ : Trm (ќУ , AвВБ) +0d}                     вЖТ ќУ , AвВБ вКҐ tвВВ вИЈ AвВВ
         вЖТ {F : Typ (ќУ , AвВБ , вЙГ AвВВ tвВВ (` AвВВ z)) dвВА}    вЖТ ќУ , AвВБ , вЙГ AвВВ tвВВ (` AвВВ z) вКҐ F
         вЖТ {f : Trm ќУ dвВА}                              вЖТ ќУ вКҐ f вИЈ F [ sub tвВБ , _ ] [ sub (вЙГrfl AвВБ tвВБ) ]
         вЖТ {u : Trm ќУ +0d}                             вЖТ ќУ вКҐ u вИЈ AвВБ
         вЖТ {p : Trm ќУ -1d}                             вЖТ ќУ вКҐ p вИЈ вЙГ AвВБ tвВБ u
         вЖТ AвВБ [ wkn AвВБ ] вЙЕ AвВВ
         вЖТ tвВБ [ wkn AвВБ ] вЙЕ tвВВ
         вЖТ ќУ вКҐ вЙГind AвВБ AвВВ tвВБ tвВВ F f u p
             вЙ° вЙГind BвВБ (AвВВ [ rew _ _ ]) tвВБ (tвВВ [ rew _ _ ]) (F [ rew _ _ , _ ]) f u p
             вИЈ F [ sub u , _ ] [ sub p ]
  вЙГindвВВ  : {dвВА : Dim}
         вЖТ {ќУ : Ctx}                                   вЖТ ќУ вКҐ
         вЖТ {AвВБ : Typ ќУ +0d}                            вЖТ ќУ вКҐ AвВБ
         вЖТ {AвВВ BвВВ : Typ (ќУ , AвВБ) +0d}                  вЖТ ќУ , AвВБ вКҐ AвВВ
                                                       вЖТ ќУ , AвВБ вКҐ BвВВ
                                                       вЖТ ќУ , AвВБ вКҐ AвВВ вЙ° BвВВ
         вЖТ {tвВБ : Trm ќУ +0d}                            вЖТ ќУ вКҐ tвВБ вИЈ AвВБ
         вЖТ {tвВВ : Trm (ќУ , AвВБ) +0d}                     вЖТ ќУ , AвВБ вКҐ tвВВ вИЈ AвВВ
         вЖТ {F : Typ (ќУ , AвВБ , вЙГ AвВВ tвВВ (` AвВВ z)) dвВА}    вЖТ ќУ , AвВБ , вЙГ AвВВ tвВВ (` AвВВ z) вКҐ F
         вЖТ {f : Trm ќУ dвВА}                              вЖТ ќУ вКҐ f вИЈ F [ sub tвВБ , _ ] [ sub (вЙГrfl AвВБ tвВБ) ]
         вЖТ {u : Trm ќУ +0d}                             вЖТ ќУ вКҐ u вИЈ AвВБ
         вЖТ {p : Trm ќУ -1d}                             вЖТ ќУ вКҐ p вИЈ вЙГ AвВБ tвВБ u
